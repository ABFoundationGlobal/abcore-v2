# abcore-v2 测试网节点配置
# 使用方法：cp .env.example .env，按实际情况修改后执行 docker compose up -d

# Docker 镜像 tag（从 GitHub Release 页面获取最新版本号）
TAG=vX.Y.Z

# 节点数据目录（链数据 + keystore 均存放于此）
DATADIR=/data/abcore-v2/testnet

# NAT 配置：公网节点填 extip:<YOUR_PUBLIC_IP>，本地测试留空
NAT=

# ── 验证者模式（普通节点保持以下两项为空/false）──────────────────────────
# 启用出块：true 表示验证者模式
MINE=false
# 验证者地址（keystore 文件对应的 0x 地址）
MINER_ADDR=
